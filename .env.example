# ──────────────────────────────────────────────────────────────────────────────
# BotifyX Platform — Environment Variables
# Copy this to .env and fill in the values before starting the server.
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Railway/Heroku: this is set automatically by the Postgres add-on.
# Termux local:  postgresql://botifyx:botifyx@localhost:5432/botifyx
DATABASE_URL=postgresql://botifyx:botifyx@localhost:5432/botifyx

# ── Session ───────────────────────────────────────────────────────────────────
# Any long random string works. On Termux: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# For local testing you can leave these blank — only Google sign-in will be broken,
# email/password auth works without them.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Termux local:
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Production (Railway/Heroku):
# GOOGLE_CALLBACK_URL=https://your-app.railway.app/auth/google/callback

# ── Bot Deployment (not needed for local UI testing) ─────────────────────────
RAILWAY_API_TOKEN=
HEROKU_API_KEY=

# ── Your existing Portal URL ──────────────────────────────────────────────────
PORTAL_URL=https://your-portal.railway.app

# ── Bot repo to deploy from (default is fine) ────────────────────────────────
BOTIFYX_REPO=Stark-iindustries/BotifyX
