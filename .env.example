# ── Database ────────────────────────────────────────────────────────────────
# Auto-set by Railway/Heroku Postgres add-on. Fill manually for local dev.
DATABASE_URL=postgresql://user:password@localhost:5432/botifyx_platform

# ── Sessions ────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Token Encryption ─────────────────────────────────────────────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=change_me_32_chars_exactly_here!!

# ── App Config ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# URL of your BotifyX Portal (for session ID generation link)
PORTAL_URL=https://your-portal.railway.app

# Your public BotifyX GitHub repo (source for all deployments)
BOTIFYX_REPO=Stark-iindustries/BotifyX
